# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Firebase config (contains project identifiers — keep private, especially for a public repo)
android/app/google-services.json
ios/Runner/GoogleService-Info.plist

# API keys / secrets you're not hardcoding but might drop into local files
.env
env.json
run_dev.sh

# Android signing (NEVER commit these — real secrets)
android/app/*.keystore
android/app/*.jks
android/key.properties
android/local.properties

# VS Code launch config, if you put the real API key in it
.vscode/launch.json
